<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Constructora</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Source+Sans+3:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        :root { --am: #F5A800; --neg: #111; }
        body  { font-family: 'Source Sans 3', sans-serif; padding-top: 56px; background: #F4F2EF; }

        .navbar-brand { font-family:'Bebas Neue',sans-serif; letter-spacing:2px; color:var(--am)!important; }
        .nav-link.activo { color: var(--am)!important; }
        .btn-nav-login { color:rgba(255,255,255,.75); border:1px solid rgba(255,255,255,.25); font-size:.85rem; padding:5px 14px; text-decoration:none; border-radius:2px; }
        .btn-nav-login:hover { color:#fff; border-color:rgba(255,255,255,.6); }
        .btn-nav-reg   { background:var(--am); color:#111!important; font-size:.85rem; font-weight:600; padding:5px 16px; text-decoration:none; border-radius:2px; }
        .btn-nav-reg:hover { background:#d49200; }

        .badge-rol { font-size:.7rem; padding:3px 8px; border-radius:2px; font-weight:700; letter-spacing:.5px; text-transform:uppercase; }
        .rol-administrador { background:#ef4444; color:#fff; }
        .rol-empleado      { background:#3b82f6; color:#fff; }
        .rol-cliente       { background:#22c55e; color:#fff; }

        .sidebar { width:220px; min-height:calc(100vh - 56px); background:#1a1a1a; position:fixed; top:56px; left:0; padding:16px 0; z-index:100; overflow-y:auto; }
        .sidebar a { display:block; color:rgba(255,255,255,.6); padding:10px 20px; font-size:.88rem; text-decoration:none; border-left:3px solid transparent; transition:all .15s; }
        .sidebar a:hover, .sidebar a.activo { color:#fff; border-left-color:var(--am); background:rgba(255,255,255,.05); }
        .sidebar .s-titulo { color:rgba(255,255,255,.3); font-size:.68rem; text-transform:uppercase; letter-spacing:1.5px; padding:14px 20px 4px; }
        .con-sidebar { margin-left:220px; }

        footer { background:#111; color:rgba(255,255,255,.45); margin-left:0; }
        .con-sidebar ~ footer, .con-sidebar + footer { margin-left:220px; }

        @@media (max-width:768px) {
            .sidebar { display:none; }
            .con-sidebar { margin-left:0; }
        }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark fixed-top" style="background:#111; border-bottom:3px solid #F5A800;">
    <div class="container-fluid px-3">
        @Html.ActionLink("CONSTRUCTORA", "Index", "Home", new { area = "" }, new { @class = "navbar-brand me-4" })
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMenu">

            @if (Session["Rol"] == null)
            {
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        @Html.ActionLink("Inicio",    "Index", "Home",     null, new { @class = "nav-link" + (ViewBag.Pagina == "inicio"   ? " activo" : "") })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Proyectos", "Index", "Catalogo", null, new { @class = "nav-link" + (ViewBag.Pagina == "catalogo" ? " activo" : "") })
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#contacto">Contacto</a>
                    </li>
                </ul>
                <div class="d-flex align-items-center gap-2">
                    <a href="@Url.Action("Login",    "Account")" class="btn-nav-login">Iniciar sesion</a>
                    <a href="@Url.Action("Register", "Account")" class="btn-nav-reg">Registrarse</a>
                </div>
            }
            else
            {
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        @Html.ActionLink("Inicio", "Index", "Home", null, new { @class = "nav-link" })
                    </li>
                </ul>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge-rol rol-@Session["Rol"]">@Session["Rol"]</span>
                    <span style="color:#F5A800; font-size:.85rem; font-weight:600;">@Session["Nombre"]</span>
                    @using (Html.BeginForm("Logout", "Account", FormMethod.Post, new { @class = "m-0" }))
                    {
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-secondary" style="font-size:.78rem;">
                            <i class="bi bi-box-arrow-right me-1"></i>Cerrar sesion
                        </button>
                    }
                </div>
            }

        </div>
    </div>
</nav>

@if (Session["Rol"] != null)
{
    string rol = Session["Rol"].ToString();
    <div class="sidebar">

        @if (rol == "administrador")
        {
            <div class="s-titulo">Administracion</div>
            <a href="@Url.Action("Index",      "Admin")" class="@(ViewBag.Pagina=="admin-dashboard" ? "activo" : "")"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a>
            <a href="@Url.Action("Proyectos",  "Admin")" class="@(ViewBag.Pagina=="admin-proyectos" ? "activo" : "")"><i class="bi bi-building me-2"></i>Proyectos</a>
            <a href="@Url.Action("Clientes",   "Admin")" class="@(ViewBag.Pagina=="admin-clientes"  ? "activo" : "")"><i class="bi bi-people me-2"></i>Clientes</a>
            <a href="@Url.Action("Empleados",  "Admin")" class="@(ViewBag.Pagina=="admin-empleados" ? "activo" : "")"><i class="bi bi-person-badge me-2"></i>Empleados</a>
            <a href="@Url.Action("Proveedores","Admin")" class="@(ViewBag.Pagina=="admin-prov"      ? "activo" : "")"><i class="bi bi-truck me-2"></i>Proveedores</a>
            <a href="@Url.Action("Materiales", "Admin")" class="@(ViewBag.Pagina=="admin-mat"       ? "activo" : "")"><i class="bi bi-box-seam me-2"></i>Materiales</a>
            <a href="@Url.Action("Solicitudes","Admin")" class="@(ViewBag.Pagina=="admin-solicitudes"?"activo":"")"><i class="bi bi-inbox me-2"></i>Solicitudes</a>
            <div class="s-titulo">Seguimiento</div>
            <a href="@Url.Action("Avances",  "Admin")" class="@(ViewBag.Pagina=="admin-avances"  ? "activo" : "")"><i class="bi bi-bar-chart-steps me-2"></i>Avances</a>
            <a href="@Url.Action("Facturas", "Admin")" class="@(ViewBag.Pagina=="admin-facturas" ? "activo" : "")"><i class="bi bi-receipt me-2"></i>Facturas</a>
            <a href="@Url.Action("Finanzas", "Admin")" class="@(ViewBag.Pagina=="admin-finanzas" ? "activo" : "")"><i class="bi bi-graph-up-arrow me-2"></i>Finanzas</a>
            <a href="@Url.Action("Compras",  "Admin")" class="@(ViewBag.Pagina=="admin-compras"  ? "activo" : "")"><i class="bi bi-cart3 me-2"></i>Compras</a>
            <div class="s-titulo">Sistema</div>
            <a href="@Url.Action("Usuarios", "Admin")" class="@(ViewBag.Pagina=="admin-usuarios" ? "activo" : "")"><i class="bi bi-shield-lock me-2"></i>Usuarios / Roles</a>
        }

        @if (rol == "cliente")
        {
            <div class="s-titulo">Mi cuenta</div>
            <a href="@Url.Action("Index",        "Cliente")" class="@(ViewBag.Pagina=="cli-dash"     ? "activo" : "")"><i class="bi bi-house me-2"></i>Inicio</a>
            <a href="@Url.Action("MisProyectos", "Cliente")" class="@(ViewBag.Pagina=="cli-proy"     ? "activo" : "")"><i class="bi bi-building me-2"></i>Mis proyectos</a>
            <a href="@Url.Action("Avances",      "Cliente")" class="@(ViewBag.Pagina=="cli-avances"  ? "activo" : "")"><i class="bi bi-bar-chart-steps me-2"></i>Avances</a>
            <a href="@Url.Action("Facturas",     "Cliente")" class="@(ViewBag.Pagina=="cli-facturas" ? "activo" : "")"><i class="bi bi-receipt me-2"></i>Mis facturas</a>
            <a href="@Url.Action("MisSolicitudes","Cliente")" class="@(ViewBag.Pagina=="cli-solicitudes"?"activo":"")"><i class="bi bi-send me-2"></i>Mis solicitudes</a>
        }

        @if (rol == "empleado")
        {
            <div class="s-titulo">Mi trabajo</div>
            <a href="@Url.Action("Index",      "Empleado")" class="@(ViewBag.Pagina=="emp-dash" ? "activo" : "")"><i class="bi bi-house me-2"></i>Inicio</a>
            <a href="@Url.Action("Proyectos",  "Empleado")" class="@(ViewBag.Pagina=="emp-proy" ? "activo" : "")"><i class="bi bi-building me-2"></i>Proyectos</a>
            <a href="@Url.Action("Avances",    "Empleado")" class="@(ViewBag.Pagina=="emp-av"   ? "activo" : "")"><i class="bi bi-bar-chart-steps me-2"></i>Avances</a>
            <a href="@Url.Action("Materiales", "Empleado")" class="@(ViewBag.Pagina=="emp-mat"  ? "activo" : "")"><i class="bi bi-box-seam me-2"></i>Materiales</a>
        }

    </div>
}

<div class="@(Session["Rol"] != null ? "con-sidebar" : "")">
    @if (TempData["Registro"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show m-3" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Registro"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @RenderBody()
</div>

<footer class="@(Session["Rol"] != null ? "con-sidebar" : "")">
    <div class="container-fluid px-4 py-4">
        <div class="row align-items-center">
            <div class="col-md-6 mb-2 mb-md-0">
                <span style="font-family:'Bebas Neue',sans-serif; font-size:1.1rem; letter-spacing:2px; color:#F5A800;">CONSTRUCTORA</span>
                <span class="ms-3" style="font-size:.82rem;">Calidad que se ve, durabilidad que se siente.</span>
            </div>
            <div class="col-md-6 text-md-end" style="font-size:.80rem;">
                &copy; @DateTime.Now.Year Constructora. Todos los derechos reservados.
            </div>
        </div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@RenderSection("scripts", required: false)
</body>
</html>
