@model Constructora.Models.Solicitud
@{
    ViewBag.Title  = "Nueva Solicitud";
    ViewBag.Pagina = "cli-solicitudes";
}
<style>
    .panel{padding:32px;} .sec-titulo{font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:1px;color:#111;}
    .linea{width:40px;height:4px;background:#F5A800;margin:6px 0 24px;}
    .form-control,.form-select{border-radius:0;}
    .btn-am{background:#F5A800;color:#111;border:none;font-weight:600;padding:10px 28px;border-radius:0;cursor:pointer;}
    .btn-am:hover{background:#d49200;}
    .form-wrap{background:#fff;padding:32px;max-width:700px;}
</style>
<div class="panel">
    <h2 class="sec-titulo">Nueva Solicitud</h2>
    <div class="linea"></div>

    <div class="form-wrap">
        <p class="text-muted mb-4" style="font-size:.88rem;">
            Completa el formulario y nuestro equipo revisara tu solicitud en menos de 48 horas.
        </p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger" style="border-radius:0;font-size:.85rem;">
                @Html.ValidationSummary(true)
            </div>
        }

        @using (Html.BeginForm("NuevaSolicitud", "Cliente", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label fw-semibold">Nombre del proyecto *</label>
                    @Html.TextBoxFor(m => m.NombreProyecto, new { @class="form-control", placeholder="Ej: Casa habitacion en Tuxtla" })
                    @Html.ValidationMessageFor(m => m.NombreProyecto, "", new { @class="text-danger", style="font-size:.78rem;" })
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Tipo de proyecto</label>
                    @Html.DropDownListFor(m => m.Tipo,
                        new SelectList(new[]{"Residencial","Comercial","Industrial","Remodelacion","Otro"}),
                        "— Selecciona —",
                        new { @class="form-select" })
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Ciudad / Municipio</label>
                    @Html.TextBoxFor(m => m.Ciudad, new { @class="form-control", placeholder="Ej: Tuxtla Gutierrez" })
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Presupuesto estimado (opcional)</label>
                    @Html.TextBoxFor(m => m.PresupuestoEstimado, new { @class="form-control", placeholder="0.00", type="number", step="0.01", min="0" })
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Descripcion del proyecto</label>
                    @Html.TextAreaFor(m => m.Descripcion, new { @class="form-control", rows="4", placeholder="Describe brevemente lo que necesitas..." })
                </div>
                <div class="col-12 d-flex gap-2 mt-2">
                    <button type="submit" class="btn-am">
                        <i class="bi bi-send me-1"></i>Enviar solicitud
                    </button>
                    <a href="@Url.Action("MisSolicitudes","Cliente")"
                       class="btn btn-outline-secondary" style="border-radius:0;">Cancelar</a>
                </div>
            </div>
        }
    </div>
</div>
