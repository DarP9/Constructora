@model IEnumerable<Constructora.Models.Proyecto>
@{
    ViewBag.Title  = "Mi Panel";
    ViewBag.Pagina = "cli-dash";
}
<style>
    .panel{padding:32px;} .sec-titulo{font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:1px;color:#111;}
    .linea{width:40px;height:4px;background:#F5A800;margin:6px 0 24px;}
    .card-proy{background:#fff;border-top:4px solid #F5A800;padding:20px;margin-bottom:12px;}
</style>
<div class="panel">
    <h2 class="sec-titulo">Bienvenido, @Session["Nombre"]</h2>
    <div class="linea"></div>
    <p class="text-muted mb-4" style="font-size:.9rem;">Aqui puedes ver el estado de tus proyectos, avances y facturas.</p>

    <h5 style="font-family:'Bebas Neue',sans-serif;letter-spacing:1px;">Proyectos recientes</h5>
    @if (!Model.Any())
    {
        <div class="alert alert-info" style="border-radius:0;">No tienes proyectos asignados aun.</div>
    }
    @foreach (var p in Model.Take(4))
    {
        <div class="card-proy">
            <div class="d-flex justify-content-between align-items-center">
                <strong>@p.NombreProyecto</strong>
                <span class="badge @(p.Estado=="Entregado"?"bg-success":"bg-warning text-dark")">@p.Estado</span>
            </div>
            <div style="font-size:.82rem;color:#666;margin-top:6px;">
                Inicio: @p.FechaInicio.ToShortDateString()
                &nbsp;|&nbsp;
                Presupuesto: $@String.Format("{0:N0}", p.PresupuestoTotal)
            </div>
        </div>
    }
    <div class="mt-2">
        <a href="@Url.Action("MisProyectos","Cliente")" style="color:#F5A800;font-weight:600;font-size:.88rem;">
            Ver todos mis proyectos &rarr;
        </a>
    </div>
</div>
