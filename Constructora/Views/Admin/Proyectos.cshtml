@model IEnumerable<Constructora.Models.Proyecto>
@using Constructora.Models
@{
    ViewBag.Title = "Proyectos";
    ViewBag.Pagina = "admin-proyectos";
    var clientes = ViewBag.Clientes as List<Cliente> ?? new List<Cliente>();
}
<style>
    .panel {
        padding: 32px;
    }

    .sec-titulo {
        font-family: 'Bebas Neue',sans-serif;
        font-size: 2rem;
        letter-spacing: 1px;
        color: #111;
    }

    .linea {
        width: 40px;
        height: 4px;
        background: #F5A800;
        margin: 6px 0 24px;
    }

    .tabla th {
        background: #111;
        color: #fff;
        font-size: .8rem;
        font-weight: 500;
    }

    .btn-am {
        background: #F5A800;
        color: #111;
        border: none;
        font-weight: 600;
        padding: 8px 20px;
        border-radius: 0;
        cursor: pointer;
    }

        .btn-am:hover {
            background: #d49200;
        }

    .modal-header {
        background: #111;
        color: #fff;
    }

    .form-control, .form-select {
        border-radius: 0;
    }
</style>
<div class="panel">
    <div class="d-flex justify-content-between align-items-center mb-1">
        <h2 class="sec-titulo">Proyectos</h2>
        <button class="btn-am" data-bs-toggle="modal" data-bs-target="#modalProy">
            <i class="bi bi-plus-lg me-1"></i>Nuevo proyecto
        </button>
    </div>
    <div class="linea"></div>
    <div class="table-responsive">
        <table class="table table-sm bg-white mb-0 tabla">
            <thead>
                <tr><th>#</th><th>Nombre</th><th>Cliente</th><th>Tipo</th><th>Ciudad</th><th>Inicio</th><th>Estado</th><th>Presupuesto</th></tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-3">Sin proyectos registrados</td></tr>
}
                @foreach (var p in Model)
                {
                    <tr>
                        <td>@p.IdProyecto</td>
                        <td>@p.NombreProyecto</td>
                        <td>@p.NombreCliente</td>
                        <td>@p.Tipo</td>
                        <td>@p.Ciudad</td>
                        <td>@p.FechaInicio.ToShortDateString()</td>
                        <td><span class="badge @(p.Estado=="Entregado"?"bg-success":p.Estado=="En proceso"?"bg-warning text-dark":"bg-secondary")">@p.Estado</span></td>
                        <td>$@String.Format("{0:N0}", p.PresupuestoTotal)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="modalProy" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" style="border-radius:0;">
            <div class="modal-header">
                <h5 class="modal-title">Nuevo proyecto</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            @using (Html.BeginForm("CrearProyecto", "Admin", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <div class="modal-body row g-3">
                    <div class="col-12">
                        <label class="form-label fw-semibold">Nombre del proyecto *</label>
                        <input name="NombreProyecto" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Cliente *</label>
                        <select name="IdCliente" class="form-select" required>
                            <option value="">— Selecciona —</option>
                            @foreach (var c in clientes)
                            {
                                <option value="@c.IdCliente">@c.Nombre</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Tipo</label>
                        <select name="Tipo" class="form-select">
                            <option value="">— Sin tipo —</option>
                            <option>Residencial</option>
                            <option>Comercial</option>
                            <option>Industrial</option>
                            <option>Remodelacion</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Ciudad</label>
                        <input name="Ciudad" class="form-control" placeholder="Ej: Tuxtla Gutierrez" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Estado</label>
                        <select name="Estado" class="form-select">
                            <option>En proceso</option>
                            <option>Entregado</option>
                            <option>Cancelado</option>
                            <option>Planeacion</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Fecha inicio</label>
                        <input name="FechaInicio" type="date" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Fecha fin</label>
                        <input name="FechaFin" type="date" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Presupuesto total</label>
                        <input name="PresupuestoTotal" type="number" step="0.01" min="0" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">M2</label>
                        <input name="M2" type="number" min="0" class="form-control" placeholder="Metros cuadrados" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">URL de imagen</label>
                        <input name="Imagen" class="form-control" placeholder="https://images.unsplash.com/..." />
                        <small class="text-muted">Puedes usar una URL de Unsplash u otra imagen publica</small>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Descripcion</label>
                        <textarea name="Descripcion" class="form-control" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn-am">Guardar</button>
                </div>
            }
        </div>
    </div>
</div>
