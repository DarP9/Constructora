@model IEnumerable<Constructora.Models.Empleado>
@{
    ViewBag.Title  = "Empleados";
    ViewBag.Pagina = "admin-empleados";
}
<style>
    .panel { padding:32px; }
    .sec-titulo { font-family:'Bebas Neue',sans-serif; font-size:2rem; letter-spacing:1px; color:#111; }
    .linea { width:40px; height:4px; background:#F5A800; margin:6px 0 24px; }
    .tabla th { background:#111; color:#fff; font-size:.8rem; font-weight:500; }
    .btn-am { background:#F5A800; color:#111; border:none; font-weight:600; padding:8px 20px; border-radius:0; cursor:pointer; }
    .btn-am:hover { background:#d49200; }
    .modal-header { background:#111; color:#fff; }
    .form-control { border-radius:0; }
</style>

<div class="panel">
    <div class="d-flex justify-content-between align-items-center mb-1">
        <h2 class="sec-titulo">Empleados</h2>
        <button class="btn-am" data-bs-toggle="modal" data-bs-target="#modalEmp">
            <i class="bi bi-plus-lg me-1"></i>Nuevo empleado
        </button>
    </div>
    <div class="linea"></div>

    <div class="table-responsive">
        <table class="table table-sm bg-white mb-0 tabla">
            <thead>
                <tr><th>#</th><th>Nombre</th><th>Puesto</th><th>Telefono</th><th>Correo</th><th>Salario</th></tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-3">Sin empleados registrados</td></tr>
                }
                @foreach (var e in Model)
                {
                    <tr>
                        <td>@e.IdEmpleado</td>
                        <td>@e.Nombre</td>
                        <td>@e.Puesto</td>
                        <td>@e.Telefono</td>
                        <td>@e.Correo</td>
                        <td>$@String.Format("{0:N2}", e.Salario)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="modalEmp" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius:0;">
            <div class="modal-header">
                <h5 class="modal-title">Nuevo empleado</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            @using (Html.BeginForm("CrearEmpleado", "Admin", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3"><label class="form-label fw-semibold">Nombre *</label><input name="Nombre"   class="form-control" required /></div>
                    <div class="mb-3"><label class="form-label fw-semibold">Puesto</label><input   name="Puesto"   class="form-control" /></div>
                    <div class="mb-3"><label class="form-label fw-semibold">Telefono</label><input name="Telefono" class="form-control" /></div>
                    <div class="mb-3"><label class="form-label fw-semibold">Correo</label><input   name="Correo"   class="form-control" type="email" /></div>
                    <div class="mb-3"><label class="form-label fw-semibold">Salario</label><input  name="Salario"  class="form-control" type="number" step="0.01" min="0" /></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn-am">Guardar</button>
                </div>
            }
        </div>
    </div>
</div>
