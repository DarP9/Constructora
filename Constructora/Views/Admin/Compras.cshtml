@model IEnumerable<Constructora.Models.CompraProveedor>
@using Constructora.Models
@{
    ViewBag.Title = "Compras";
    ViewBag.Pagina = "admin-compras";
    var proveedores = Constructora.Models.DbHelper.ListarProveedores();
    var materiales = Constructora.Models.DbHelper.ListarMateriales();
}
<style>
    .panel {
        padding: 32px;
    }

    .sec-titulo {
        font-family: 'Bebas Neue',sans-serif;
        font-size: 2rem;
        letter-spacing: 1px;
        color: #111;
    }

    .linea {
        width: 40px;
        height: 4px;
        background: #F5A800;
        margin: 6px 0 24px;
    }

    .tabla th {
        background: #111;
        color: #fff;
        font-size: .8rem;
        font-weight: 500;
    }

    .btn-am {
        background: #F5A800;
        color: #111;
        border: none;
        font-weight: 600;
        padding: 8px 20px;
        border-radius: 0;
        cursor: pointer;
    }

        .btn-am:hover {
            background: #d49200;
        }

    .modal-header {
        background: #111;
        color: #fff;
    }

    .form-control, .form-select {
        border-radius: 0;
    }
</style>
<div class="panel">
    <div class="d-flex justify-content-between align-items-center mb-1">
        <h2 class="sec-titulo">Compras a Proveedores</h2>
        <button class="btn-am" data-bs-toggle="modal" data-bs-target="#modalCompra">
            <i class="bi bi-plus-lg me-1"></i>Nueva compra
        </button>
    </div>
    <div class="linea"></div>
    <div class="table-responsive">
        <table class="table table-sm bg-white mb-0 tabla">
            <thead><tr><th>#</th><th>Proveedor</th><th>Material</th><th>Cant.</th><th>Precio</th><th>Subtotal</th><th>Fecha</th></tr></thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-3">Sin compras registradas</td></tr>
}
                @foreach (var c in Model)
                {
                    <tr>
                        <td>@c.IdCompra</td>
                        <td>@c.Proveedor</td>
                        <td>@c.Material</td>
                        <td>@c.Cantidad</td>
                        <td>$@String.Format("{0:N2}", c.Precio)</td>
                        <td>$@String.Format("{0:N2}", c.Subtotal)</td>
                        <td>@c.Fecha.ToShortDateString()</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="modalCompra" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius:0;">
            <div class="modal-header">
                <h5 class="modal-title">Nueva compra</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            @using (Html.BeginForm("CrearCompra", "Admin", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Proveedor *</label>
                        <select name="IdProveedor" class="form-select" required>
                            <option value="">— Selecciona —</option>
                            @foreach (var p in proveedores)
                            {
                                <option value="@p.IdProveedor">@p.Nombre</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Material *</label>
                        <select name="IdMaterial" class="form-select" required>
                            <option value="">— Selecciona —</option>
                            @foreach (var m in materiales)
                            {
                                <option value="@m.IdMaterial">@m.Nombre</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Cantidad *</label>
                        <input name="Cantidad" type="number" min="1" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Precio unitario *</label>
                        <input name="Precio" type="number" step="0.01" min="0" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Fecha</label>
                        <input name="Fecha" type="date" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn-am">Guardar</button>
                </div>
            }
        </div>
    </div>
</div>
