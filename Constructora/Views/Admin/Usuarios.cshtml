@model IEnumerable<Constructora.Models.Usuario>
@{
    ViewBag.Title = "Usuarios y Roles";
    ViewBag.Pagina = "admin-usuarios";
}
<style>
    .panel {
        padding: 32px;
    }

    .sec-titulo {
        font-family: 'Bebas Neue',sans-serif;
        font-size: 2rem;
        letter-spacing: 1px;
        color: #111;
    }

    .linea {
        width: 40px;
        height: 4px;
        background: #F5A800;
        margin: 6px 0 24px;
    }

    .tabla th {
        background: #111;
        color: #fff;
        font-size: .8rem;
        font-weight: 500;
    }

    .btn-am {
        background: #F5A800;
        color: #111;
        border: none;
        font-weight: 600;
        padding: 8px 20px;
        border-radius: 0;
        cursor: pointer;
    }

        .btn-am:hover {
            background: #d49200;
        }

    .modal-header {
        background: #111;
        color: #fff;
    }

    .form-control, .form-select {
        border-radius: 0;
    }

    .sel-rol {
        border: 1px solid #ddd;
        padding: 4px 8px;
        font-size: .82rem;
        border-radius: 0;
        background: #fff;
    }

    .btn-am-xs {
        background: #F5A800;
        color: #111;
        border: none;
        font-weight: 600;
        padding: 4px 12px;
        font-size: .82rem;
        border-radius: 0;
        cursor: pointer;
    }

        .btn-am-xs:hover {
            background: #d49200;
        }
</style>

<div class="panel">
    <div class="d-flex justify-content-between align-items-center mb-1">
        <h2 class="sec-titulo">Usuarios y Roles</h2>
        <button class="btn-am" data-bs-toggle="modal" data-bs-target="#modalCrear">
            <i class="bi bi-plus-lg me-1"></i>Nuevo usuario
        </button>
    </div>
    <div class="linea"></div>

    @if (TempData["OkUsuario"] != null)
    {
        <div class="alert alert-success" style="border-radius:0;font-size:.85rem;">
            <i class="bi bi-check-circle me-2"></i>@TempData["OkUsuario"]
        </div>
    }

    <p class="text-muted mb-3" style="font-size:.85rem;">Gestiona roles, edita o elimina usuarios del sistema.</p>

    <div class="table-responsive">
        <table class="table table-sm bg-white mb-0 tabla">
            <thead>
                <tr><th>#</th><th>Nombre</th><th>Correo</th><th>Rol actual</th><th>Registro</th><th>Cambiar rol</th><th>Editar</th><th>Eliminar</th></tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-3">Sin usuarios</td></tr>
}
                @foreach (var u in Model)
                {
                    <tr>
                        <td>@u.IdUsuario</td>
                        <td>@u.Nombre</td>
                        <td>@u.Correo</td>
                        <td>
                            <span class="badge @(u.Rol=="administrador"?"bg-danger":u.Rol=="empleado"?"bg-primary":"bg-success")">
                                @u.Rol
                            </span>
                        </td>
                        <td>@u.FechaRegistro.ToShortDateString()</td>
                        <td>
                            @using (Html.BeginForm("CambiarRol", "Admin", FormMethod.Post,
                                new { @class = "d-flex gap-1 align-items-center" }))
                            {
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="idUsuario" value="@u.IdUsuario" />
                                <select name="nuevoRol" class="sel-rol">
                                    <option value="cliente" @(u.Rol == "cliente" ? "selected" : "")>cliente</option>
                                    <option value="empleado" @(u.Rol == "empleado" ? "selected" : "")>empleado</option>
                                    <option value="administrador" @(u.Rol == "administrador" ? "selected" : "")>administrador</option>
                                </select>
                                <button type="submit" class="btn-am-xs">Guardar</button>
                            }
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-secondary" style="border-radius:0;font-size:.78rem;"
                                    data-bs-toggle="modal" data-bs-target="#modalEditar"
                                    data-id="@u.IdUsuario"
                                    data-nombre="@u.Nombre"
                                    data-correo="@u.Correo">
                                <i class="bi bi-pencil"></i>
                            </button>
                        </td>
                        <td>
                            @using (Html.BeginForm("EliminarUsuario", "Admin", FormMethod.Post,
                                new { onsubmit = "return confirm('żEliminar este usuario?')" }))
                            {
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="idUsuario" value="@u.IdUsuario" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" style="border-radius:0;font-size:.78rem;">
                                    <i class="bi bi-trash"></i>
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="modalCrear" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius:0;">
            <div class="modal-header">
                <h5 class="modal-title">Nuevo usuario</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            @using (Html.BeginForm("CrearUsuarioAdmin", "Admin", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3"><label class="form-label fw-semibold">Nombre *</label><input name="Nombre" class="form-control" required /></div>
                    <div class="mb-3"><label class="form-label fw-semibold">Correo *</label><input name="Correo" class="form-control" type="email" required /></div>
                    <div class="mb-3"><label class="form-label fw-semibold">Contrasena *</label><input name="Password" class="form-control" type="password" required /></div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Rol</label>
                        <select name="Rol" class="form-select">
                            <option value="cliente">cliente</option>
                            <option value="empleado">empleado</option>
                            <option value="administrador">administrador</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn-am">Crear</button>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="modalEditar" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius:0;">
            <div class="modal-header">
                <h5 class="modal-title">Editar usuario</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            @using (Html.BeginForm("EditarUsuario", "Admin", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" name="IdUsuario" id="edit-id" />
                    <div class="mb-3"><label class="form-label fw-semibold">Nombre *</label><input name="Nombre" id="edit-nombre" class="form-control" required /></div>
                    <div class="mb-3"><label class="form-label fw-semibold">Correo *</label><input name="Correo" id="edit-correo" class="form-control" type="email" required /></div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nueva contrasena</label>
                        <input name="Password" class="form-control" type="password" placeholder="Dejar vacio para no cambiar" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn-am">Guardar</button>
                </div>
            }
        </div>
    </div>
</div>

@section scripts {
    <script>document.getElementById('modalEditar').addEventListener('show.bs.modal', function(e) {
        var btn = e.relatedTarget;
        document.getElementById('edit-id').value     = btn.getAttribute('data-id');
        document.getElementById('edit-nombre').value = btn.getAttribute('data-nombre');
        document.getElementById('edit-correo').value = btn.getAttribute('data-correo');
    });</script>
}
