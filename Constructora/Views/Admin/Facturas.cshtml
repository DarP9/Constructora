@model IEnumerable<Constructora.Models.Factura>
@using Constructora.Models
@{
    ViewBag.Title = "Facturas";
    ViewBag.Pagina = "admin-facturas";
    var proyectos = Constructora.Models.DbHelper.ListarProyectos();
}
<style>
    .panel {
        padding: 32px;
    }

    .sec-titulo {
        font-family: 'Bebas Neue',sans-serif;
        font-size: 2rem;
        letter-spacing: 1px;
        color: #111;
    }

    .linea {
        width: 40px;
        height: 4px;
        background: #F5A800;
        margin: 6px 0 24px;
    }

    .tabla th {
        background: #111;
        color: #fff;
        font-size: .8rem;
        font-weight: 500;
    }

    .btn-am {
        background: #F5A800;
        color: #111;
        border: none;
        font-weight: 600;
        padding: 8px 20px;
        border-radius: 0;
        cursor: pointer;
    }

        .btn-am:hover {
            background: #d49200;
        }

    .modal-header {
        background: #111;
        color: #fff;
    }

    .form-control, .form-select {
        border-radius: 0;
    }
</style>
<div class="panel">
    <div class="d-flex justify-content-between align-items-center mb-1">
        <h2 class="sec-titulo">Facturas</h2>
        <button class="btn-am" data-bs-toggle="modal" data-bs-target="#modalFactura">
            <i class="bi bi-plus-lg me-1"></i>Nueva factura
        </button>
    </div>
    <div class="linea"></div>
    <div class="table-responsive">
        <table class="table table-sm bg-white mb-0 tabla">
            <thead><tr><th>#</th><th>Proyecto</th><th>Cliente</th><th>Monto</th><th>Fecha</th><th>Estado pago</th></tr></thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-3">Sin facturas</td></tr>
}
                @foreach (var f in Model)
                {
                    <tr>
                        <td>@f.IdFactura</td>
                        <td>@f.NombreProyecto</td>
                        <td>@f.NombreCliente</td>
                        <td>$@String.Format("{0:N2}", f.Monto)</td>
                        <td>@f.Fecha.ToShortDateString()</td>
                        <td><span class="badge @(f.EstadoPago=="Pagado"?"bg-success":f.EstadoPago=="Pendiente"?"bg-warning text-dark":"bg-secondary")">@f.EstadoPago</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="modalFactura" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius:0;">
            <div class="modal-header">
                <h5 class="modal-title">Nueva factura</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            @using (Html.BeginForm("CrearFactura", "Admin", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Proyecto *</label>
                        <select name="IdProyecto" class="form-select" required>
                            <option value="">— Selecciona —</option>
                            @foreach (var p in proyectos)
                            {
                                <option value="@p.IdProyecto">@p.NombreProyecto</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Monto *</label>
                        <input name="Monto" type="number" step="0.01" min="0" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Fecha</label>
                        <input name="Fecha" type="date" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Estado de pago</label>
                        <select name="EstadoPago" class="form-select">
                            <option value="Pendiente">Pendiente</option>
                            <option value="Pagado">Pagado</option>
                            <option value="Cancelado">Cancelado</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn-am">Guardar</button>
                </div>
            }
        </div>
    </div>
</div>

